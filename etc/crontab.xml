<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="angeo_aeo_audit" instance="Angeo\AeoAudit\Cron\AuditCron" method="execute">
            <!-- Every Monday at 03:00 — off-peak, weekly cadence -->
            <schedule>0 3 * * 1</schedule>
        </job>
    </group>
</config>
