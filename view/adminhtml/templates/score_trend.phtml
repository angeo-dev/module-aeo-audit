<script>
    (function () {
        'use strict';

        const HISTORY_URL = '<?= $block->escapeJs($historyUrl) ?>';
        let chart = null;

        // ── Color palette per store ──────────────────────────────────────────────
        const PALETTE = [
            '#2563eb', '#059669', '#d97706', '#7c3aed',
            '#db2777', '#0891b2', '#65a30d', '#ea580c',
        ];

        // ── Chart.js CDN load ────────────────────────────────────────────────────
        function loadChartJs(callback) {
            if (window.Chart) { callback(); return; }
            const s = document.createElement('script');
            s.src = 'https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js';
            s.onload = callback;
            document.head.appendChild(s);
        }

        // ── Fetch history data ───────────────────────────────────────────────────
        function fetchHistory(store, days, callback) {
            const url = HISTORY_URL + '?store=' + encodeURIComponent(store) + '&days=' + days;
            const xhr = new XMLHttpRequest();
            xhr.open('GET', url, true);
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
            xhr.onreadystatechange = function () {
                if (xhr.readyState === 4) {
                    try { callback(JSON.parse(xhr.responseText)); }
                    catch (e) { callback({ success: false, error: 'Parse error' }); }
                }
            };
            xhr.send();
        }

        // ── Render chart ─────────────────────────────────────────────────────────
        function renderChart(data) {
            const canvas  = document.getElementById('angeo-trend-chart');
            const loading = document.getElementById('angeo-chart-loading');
            const subtitle = document.getElementById('angeo-chart-subtitle');

            if (!data.success || !data.data || Object.keys(data.data).length === 0) {
                loading.textContent = 'No data for selected range.';
                canvas.style.display = 'none';
                return;
            }

            loading.style.display = 'none';
            canvas.style.display = 'block';

            // Collect all unique dates across all stores
            const allDates = new Set();
            Object.values(data.data).forEach(function (points) {
                points.forEach(function (p) { allDates.add(p.date.substring(0, 16)); });
            });
            const labels = Array.from(allDates).sort();

            // Build datasets
            const datasets = [];
            let colorIdx = 0;
            Object.entries(data.data).forEach(function ([storeCode, points]) {
                const color = PALETTE[colorIdx % PALETTE.length];
                colorIdx++;

                // Map date → score
                const scoreByDate = {};
                points.forEach(function (p) { scoreByDate[p.date.substring(0, 16)] = p.score; });

                const values = labels.map(function (d) {
                    return scoreByDate[d] !== undefined ? scoreByDate[d] : null;
                });

                datasets.push({
                    label:                storeCode,
                    data:                 values,
                    borderColor:          color,
                    backgroundColor:      color + '18',
                    pointBackgroundColor: color,
                    pointRadius:          4,
                    pointHoverRadius:     6,
                    borderWidth:          2.5,
                    tension:              0.3,
                    spanGaps:             true,
                    fill:                 datasets.length === 0, // fill only first dataset
                });
            });

            // Format labels for display
            const displayLabels = labels.map(function (d) {
                const dt = new Date(d);
                return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
            });

            // Update subtitle
            const totalPoints = Object.values(data.data).reduce(function (s, p) { return s + p.length; }, 0);
            subtitle.textContent = totalPoints + ' audit' + (totalPoints !== 1 ? 's' : '') + ' · last ' + data.days + ' days';

            // Destroy previous chart
            if (chart) { chart.destroy(); chart = null; }

            chart = new Chart(canvas, {
                type: 'line',
                data: {
                    labels:   displayLabels,
                    datasets: datasets,
                },
                options: {
                    responsive:          true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode:      'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            display:  datasets.length > 1,
                            position: 'top',
                            labels:   { font: { size: 12 }, boxWidth: 14, padding: 16 },
                        },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    return ' ' + ctx.dataset.label + ': ' + ctx.parsed.y + '%';
                                },
                            },
                        },
                    },
                    scales: {
                        x: {
                            grid:   { color: '#f3f4f6' },
                            ticks:  { font: { size: 11 }, color: '#9ca3af', maxTicksLimit: 10, maxRotation: 30 },
                        },
                        y: {
                            min:    0,
                            max:    100,
                            grid:   { color: '#f3f4f6' },
                            ticks:  {
                                font:     { size: 11 },
                                color:    '#9ca3af',
                                callback: function (v) { return v + '%'; },
                                stepSize: 20,
                            },
                            // Reference lines
                            afterDataLimits: function (axis) { axis.max = 100; },
                        },
                    },
                },
                plugins: [{
                    // Draw reference lines at 65% (Good) and 85% (Excellent)
                    id: 'referenceLines',
                    afterDraw: function (ch) {
                        const ctx2 = ch.ctx;
                        const yAxis = ch.scales.y;
                        const xLeft  = ch.chartArea.left;
                        const xRight = ch.chartArea.right;

                        [[85, '#059669', 'Excellent'], [65, '#d97706', 'Good']].forEach(function ([val, color, label]) {
                            const y = yAxis.getPixelForValue(val);
                            ctx2.save();
                            ctx2.setLineDash([6, 4]);
                            ctx2.strokeStyle = color + '60';
                            ctx2.lineWidth   = 1.5;
                            ctx2.beginPath();
                            ctx2.moveTo(xLeft, y);
                            ctx2.lineTo(xRight, y);
                            ctx2.stroke();
                            ctx2.fillStyle  = color;
                            ctx2.font       = '10px sans-serif';
                            ctx2.textAlign  = 'right';
                            ctx2.fillText(label + ' ' + val + '%', xRight - 4, y - 4);
                            ctx2.restore();
                        });
                    },
                }],
            });
        }

        // ── Reload chart ─────────────────────────────────────────────────────────
        function reload() {
            const store = document.getElementById('angeo-store-select')?.value || '';
            const days  = document.getElementById('angeo-days-select')?.value || '30';
            const loading = document.getElementById('angeo-chart-loading');
            const canvas  = document.getElementById('angeo-trend-chart');

            if (!loading) return;

            loading.style.display = 'block';
            loading.textContent   = 'Loading chart data...';
            if (canvas) canvas.style.display = 'none';

            loadChartJs(function () {
                fetchHistory(store, days, renderChart);
            });
        }

        // ── Init ─────────────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
            const storeSelect = document.getElementById('angeo-store-select');
            const daysSelect  = document.getElementById('angeo-days-select');
            const refreshBtn  = document.getElementById('angeo-refresh-btn');

            if (storeSelect) storeSelect.addEventListener('change', reload);
            if (daysSelect)  daysSelect.addEventListener('change', reload);
            if (refreshBtn)  refreshBtn.addEventListener('click', reload);

            reload();
        });

    }());
</script>
