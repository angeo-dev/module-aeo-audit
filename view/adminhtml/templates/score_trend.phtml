<?php
/**
 * Score Trend page — markup only.
 *
 * 3.1.0: all JS moved to Angeo_AeoAudit/js/score-trend (x-magento-init),
 * all CSS moved to Angeo_AeoAudit::css/score-trend.css, Chart.js bundled
 * locally. "Run Audit Now" submits a POST form with the admin form key.
 */

/** @var \Angeo\AeoAudit\Block\Adminhtml\ScoreTrend $block */
/** @var \Magento\Framework\Escaper $escaper */
$historyUrl   = $block->getHistoryUrl();
$runNowUrl    = $block->getRunNowUrl();
$indexUrl     = $block->getResultsIndexUrl();
$latestScores = $block->getLatestScores();
$hasData      = $block->hasAuditData();
?>

<div class="angeo-trend">

    <!-- Header -->
    <div class="angeo-trend-header">
        <h1>📈 <?= $escaper->escapeHtml(__('AEO Score Trend')) ?></h1>
        <div class="angeo-trend-controls">
            <select class="angeo-select" id="angeo-store-select">
                <option value=""><?= $escaper->escapeHtml(__('All stores')) ?></option>
                <?php foreach (array_keys($latestScores) as $storeCode): ?>
                    <option value="<?= $escaper->escapeHtmlAttr($storeCode) ?>">
                        <?= $escaper->escapeHtml($storeCode) ?>
                    </option>
                <?php endforeach; ?>
            </select>
            <select class="angeo-select" id="angeo-days-select">
                <option value="7"><?= $escaper->escapeHtml(__('Last 7 days')) ?></option>
                <option value="30" selected><?= $escaper->escapeHtml(__('Last 30 days')) ?></option>
                <option value="90"><?= $escaper->escapeHtml(__('Last 90 days')) ?></option>
                <option value="365"><?= $escaper->escapeHtml(__('Last year')) ?></option>
            </select>
            <button type="button" class="angeo-btn angeo-btn-secondary" id="angeo-refresh-btn">
                ↻ <?= $escaper->escapeHtml(__('Refresh')) ?>
            </button>
            <form class="angeo-inline-form"
                  action="<?= $escaper->escapeUrl($runNowUrl) ?>"
                  method="post">
                <?= /* admin form key — canonical block render */ $block->getBlockHtml('formkey') ?>
                <button type="submit" class="angeo-btn angeo-btn-primary">
                    ▶ <?= $escaper->escapeHtml(__('Run Audit Now')) ?>
                </button>
            </form>
        </div>
    </div>

    <?php if (!$hasData): ?>
        <!-- Empty state -->
        <div class="angeo-empty">
            <h3><?= $escaper->escapeHtml(__('No audit history yet')) ?></h3>
            <p><?= $escaper->escapeHtml(__('Run your first AEO audit to start tracking your score over time.')) ?></p>
            <form class="angeo-inline-form"
                  action="<?= $escaper->escapeUrl($runNowUrl) ?>"
                  method="post">
                <?= /* admin form key — canonical block render */ $block->getBlockHtml('formkey') ?>
                <button type="submit" class="angeo-btn angeo-btn-primary">
                    ▶ <?= $escaper->escapeHtml(__('Run First Audit')) ?>
                </button>
            </form>
        </div>

    <?php else: ?>

        <!-- Score cards — latest result per store -->
        <div class="angeo-score-cards" id="angeo-score-cards">
            <?php foreach ($latestScores as $storeCode => $data):
                $score = (int) $data['score'];
                $scoreClass = $score >= 85 ? 'score-excellent' : ($score >= 65 ? 'score-good' : 'score-poor');
                ?>
                <div class="angeo-score-card <?= $escaper->escapeHtmlAttr($scoreClass) ?>">
                    <div class="store-name"><?= $escaper->escapeHtml($storeCode) ?></div>
                    <div class="score-big"><?= /* @noEscape */ $score ?>%</div>
                    <div class="score-label"><?= $escaper->escapeHtml($data['label']) ?></div>
                    <div class="score-pills">
                        <span class="angeo-pill pass">✓ <?= (int)$data['pass'] ?></span>
                        <span class="angeo-pill warn">⚠ <?= (int)$data['warn'] ?></span>
                        <span class="angeo-pill fail">✗ <?= (int)$data['fail'] ?></span>
                    </div>
                    <div class="last-run">
                        <?= $escaper->escapeHtml(__('Last run: %1', date('M j, H:i', strtotime($data['created_at'])))) ?>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>

        <!-- Chart -->
        <div class="angeo-chart-card">
            <h2>
                <?= $escaper->escapeHtml(__('Score over time')) ?>
                <span class="angeo-chart-subtitle" id="angeo-chart-subtitle">
                    <?= $escaper->escapeHtml(__('Loading...')) ?>
                </span>
            </h2>
            <div class="angeo-chart-wrap">
                <div class="angeo-loading" id="angeo-chart-loading">
                    <?= $escaper->escapeHtml(__('Loading chart data...')) ?>
                </div>
                <canvas id="angeo-trend-chart"></canvas>
            </div>
        </div>

        <!-- Link to full history -->
        <div class="angeo-trend-footer">
            <a href="<?= $escaper->escapeUrl($indexUrl) ?>">
                <?= $escaper->escapeHtml(__('View all audit results →')) ?>
            </a>
        </div>

    <?php endif; ?>

</div>

<?php if ($hasData): ?>
<script type="text/x-magento-init">
{
    "#angeo-score-cards": {
        "Angeo_AeoAudit/js/score-trend": {
            "historyUrl": "<?= $escaper->escapeJs($historyUrl) ?>"
        }
    }
}
</script>
<?php endif; ?>
