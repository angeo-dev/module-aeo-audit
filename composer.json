            "homepage": "https://angeo.dev"
        }
    ],
    "keywords": [
        "magento2",
        "magento 2 module",
        "aeo",
        "aeo audit",
        "ai engine optimization",
        "ai seo",
        "llms.txt",
        "robots.txt",
        "structured data",
        "schema markup",
        "chatgpt",
        "gemini",
        "ai visibility",
        "angeo"
    ],
    "homepage": "https://angeo.dev",
    "require": {
        "php": ">=8.2",
