{
    "name": "angeo/module-aeo-audit",
    "description": "Magento 2 AEO (AI Engine Optimization) Audit Tool. Deep audit for AI-readiness: robots.txt parser, llms.txt spec validation, Product/FAQ schema, sitemap, product feed, OG tags, canonical. Includes Admin UI with cron scheduling.",
    "type": "magento2-module",
    "version": "2.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Ievgenii Gryshkun",
            "email": "info@angeo.dev",
            "homepage": "https://angeo.dev"
        }
    ],
    "keywords": [
        "magento2",
        "magento 2 module",
        "aeo",
        "aeo audit",
        "ai engine optimization",
        "ai seo",
        "ai visibility",
        "llms.txt",
        "robots.txt",
        "structured data",
        "schema markup",
        "ChatGpt",
        "Gemini",
        "angeo"
    ],
    "homepage": "https://angeo.dev",
    "require": {
        "php": ">=8.2",
        "magento/framework": "*",
        "magento/module-store": "*",
        "magento/module-catalog": "*",
        "magento/module-cms": "*",
        "magento/module-backend": "*",
        "magento/module-ui": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "suggest": {
        "angeo/module-llms-txt": "Automatically generate llms.txt after audit.",
        "angeo/module-openai-product-feed": "Generate AI product feed after audit."
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Angeo\\AeoAudit\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Angeo\\AeoAudit\\Test\\": "Test/"
        }
    }
}
