parameters:
    level: 5
    paths:
        - Api
        - Block
        - Console
        - Controller
        - Cron
        - Model
        - Ui
    excludePaths:
        - Test/*
        - vendor/*
    ignoreErrors:
        - '#Call to an undefined method Magento#'
        - '#has invalid type Magento\\#'
    treatPhpDocTypesAsCertain: false
